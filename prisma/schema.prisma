// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int       @id @default(autoincrement())
  email           String?   @unique
  userName        String?   @unique
  password        String
  nombres         String
  apellidos       String
  cedula          String    @unique
  fechaNacimiento String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships           UserTenant[]
  staffProfiles         StaffProfile[]
  administrador         Administrador[]
  entrenador            Entrenador[]
  recepcionista         Recepcionista[]
  cliente               Cliente[]
  gastos                Gasto[]
  devolucionMovimientos DevolucionMovimiento[]
}

model Tenant {
  id          Int          @id @default(autoincrement())
  nombre      String
  slug        String       @unique
  tipoNegocio TipoNegocio
  estado      TenantEstado @default(ACTIVO)

  email       String?
  telefono    String?
  direccion   String?
  ciudad      String?
  pais        String?
  logoUrl     String?
  descripcion String?

  latitud   Float?
  longitud  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 UserTenant[]
  staffProfiles         StaffProfile[]
  modules               TenantModule[]
  clientes              Cliente[]
  clienteMedidas        ClienteMedida[]
  novedades             Novedad[]
  productos             Producto[]
  compras               Compra[]
  planes                Plan[]
  clientesPlan          ClientePlan[]
  pagos                 Pago[]
  deudas                Deuda[]
  facturas              Factura[]
  gastos                Gasto[]
  ingresosRapidos       IngresoRapido[]
  asistencias           Asistencia[]
  rutinas               Rutina[]
  entrenamientos        Entrenamiento[]
  semanas               Semana[]
  musculosSemana        MusculoSemana[]
  ejerciciosMusculo     EjercicioMusculo[]
  cambiosPlan           CambioPlan[]
  devolucionMovimientos DevolucionMovimiento[]

  @@index([tipoNegocio])
  @@index([estado])
}

model UserTenant {
  id        Int              @id @default(autoincrement())
  usuarioId Int
  tenantId  Int
  role      TenantRole
  estado    UserTenantEstado @default(ACTIVO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tenantId])
  @@index([tenantId, role])
  @@index([usuarioId])
}

model TenantModule {
  id       Int       @id @default(autoincrement())
  tenantId Int
  module   ModuleKey
  activo   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
}

model Administrador {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Entrenador {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  horario   String
  sueldo    Float
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Recepcionista {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  horario   String
  sueldo    Float
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model StaffProfile {
  id         Int        @id @default(autoincrement())
  usuarioId  Int
  tenantId   Int
  tenantRole TenantRole
  horario    String
  sueldo     Float
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tenantId, tenantRole])
  @@index([tenantId])
  @@index([usuarioId])
  @@index([tenantId, tenantRole])
}

model Cliente {
  id             Int     @id @default(autoincrement())
  usuarioId      Int
  tenantId       Int
  horario        String
  sexo           String
  observaciones  String
  objetivos      String
  tiempoEntrenar Int
  activo         Boolean @default(true)

  usuario        Usuario         @relation(fields: [usuarioId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  clienteMedidas ClienteMedida[]
  novedades      Novedad[]
  compras        Compra[]
  planes         ClientePlan[]
  rutinas        Rutina[]
  asistencias    Asistencia[]
  cambiosPlan    CambioPlan[]

  @@unique([usuarioId, tenantId])
  @@index([usuarioId])
  @@index([tenantId])
}

model Medida {
  id             Int             @id @default(autoincrement())
  nombre         String
  clienteMedidas ClienteMedida[]
}

model ClienteMedida {
  id        Int @id @default(autoincrement())
  tenantId  Int
  clienteId Int
  medidaId  Int
  medida    Int

  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  cliente    Cliente @relation(fields: [clienteId], references: [id])
  medidaTipo Medida  @relation(fields: [medidaId], references: [id])

  @@index([tenantId])
}

model Novedad {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  clienteId  Int
  novedad    String
  fecha      DateTime
  solventada Boolean

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@index([tenantId])
}

model Producto {
  id       Int     @id @default(autoincrement())
  tenantId Int
  nombre   String
  precio   Float
  stock    Int
  estado   Boolean

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  compras Compra[]

  @@index([tenantId])
}

model Compra {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  productoId Int
  clienteId  Int
  cantidad   Int
  total      Float
  fecha      DateTime

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
  cliente  Cliente  @relation(fields: [clienteId], references: [id])

  @@index([tenantId])
}

model Plan {
  id              Int             @id @default(autoincrement())
  tenantId        Int
  nombre          String
  precio          Float
  duracion        Int
  unidadDuracion  UnidadDuracion  @default(MESES)
  activo          Boolean         @default(true)
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  clientePlan     ClientePlan[]

  @@index([tenantId])
}

model ClientePlan {
  id          Int                @id @default(autoincrement())
  tenantId    Int
  clienteId   Int
  planId      Int
  fechaInicio DateTime
  fechaFin    DateTime
  diaPago     Int
  activado    Boolean
  estado      EstadoClientePlan  @default(ACTIVO)

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  plan            Plan         @relation(fields: [planId], references: [id])
  pago            Pago[]
  deudas          Deuda[]
  facturas        Factura[]
  cambiosComoAnterior CambioPlan[] @relation("PlanAnterior")
  cambiosComoNuevo    CambioPlan[] @relation("PlanNuevo")

  @@index([tenantId])
}

model Pago {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  clientePlanId Int
  monto         Float
  fecha         DateTime

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])

  @@index([tenantId])
  @@index([clientePlanId])
  @@index([fecha])
}

model Deuda {
  id            Int     @id @default(autoincrement())
  tenantId      Int
  clientePlanId Int
  monto         Float
  solventada    Boolean

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])

  @@index([tenantId])
}

model Rutina {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  clienteId   Int
  rutina      Bytes
  fechaInicio DateTime
  fechaFin    DateTime
  observacion String

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  entrenamiento Entrenamiento? @relation("RutinaEntrenamiento") // sin fields ni references

  @@index([tenantId])
}

model Entrenamiento {
  id         Int     @id @default(autoincrement())
  tenantId   Int
  rutinaId   Int     @unique
  finalizado Boolean

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  rutina  Rutina   @relation("RutinaEntrenamiento", fields: [rutinaId], references: [id])
  semanas Semana[]

  @@index([tenantId])
}

model Semana {
  id              Int           @id @default(autoincrement())
  tenantId        Int
  numero          Int
  entrenamientoId Int
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  entrenamiento   Entrenamiento @relation(fields: [entrenamientoId], references: [id])
  musculosSemana  MusculoSemana[]

  @@index([tenantId])
}

model MusculoSemana {
  id        Int @id @default(autoincrement())
  tenantId  Int
  semanaId  Int
  musculoId Int
  orden     Int // Orden en que se entrena este músculo en la semana

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  semana            Semana             @relation(fields: [semanaId], references: [id])
  musculo           Musculo            @relation(fields: [musculoId], references: [id])
  ejerciciosMusculo EjercicioMusculo[]

  @@index([tenantId])
}

model Musculo {
  id             Int             @id @default(autoincrement())
  nombre         String          @unique
  musculosSemana MusculoSemana[]
}

model EjercicioMusculo {
  id              Int @id @default(autoincrement())
  tenantId        Int
  musculoSemanaId Int
  ejercicioId     Int
  orden           Int // Orden en que se hace este ejercicio para el músculo

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  musculoSemana MusculoSemana @relation(fields: [musculoSemanaId], references: [id])
  ejercicio     Ejercicio     @relation(fields: [ejercicioId], references: [id])
  seriesReps    SerieRep[]
  seriesTiempos SerieTiempo[]

  @@index([tenantId])
}

model Ejercicio {
  id     Int    @id @default(autoincrement())
  nombre String @unique
  foto   Bytes? // Keeping foto from HEAD just in case

  ejerciciosMusculo EjercicioMusculo[]
}

model SerieRep {
  id                 Int    @id @default(autoincrement())
  ejercicioMusculoId Int
  orden              Int
  peso               Float
  repeticiones       Int
  unidadMedida       String

  ejercicioMusculo EjercicioMusculo @relation(fields: [ejercicioMusculoId], references: [id])
}

model SerieTiempo {
  id                 Int    @id @default(autoincrement())
  ejercicioMusculoId Int
  orden              Int
  peso               Float
  tiempo             Int
  unidadMedida       String

  ejercicioMusculo EjercicioMusculo @relation(fields: [ejercicioMusculoId], references: [id])
}

model Gasto {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  descripcion String
  monto       Float
  fecha       DateTime @default(now())
  usuarioId   Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([tenantId])
}

model IngresoRapido {
  id       Int      @id @default(autoincrement())
  tenantId Int
  concepto String
  monto    Float
  fecha    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([fecha])
}

model Asistencia {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  clienteId   Int
  fecha       DateTime @default(now())
  horaEntrada DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@unique([clienteId, fecha(sort: Desc)]) // Solo 1 asistencia por día
  @@index([tenantId])
  @@index([clienteId, fecha])
}

model Factura {
  id            Int    @id @default(autoincrement())
  numero        String @unique
  tenantId      Int
  clientePlanId Int

  subtotal Float
  iva      Float
  total    Float

  totalPagado     Float @default(0)
  creditoAplicado Float @default(0)
  saldo           Float

  estado       EstadoFactura
  fechaEmision DateTime      @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])
  devoluciones DevolucionMovimiento[]

  @@index([tenantId])
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  ANULADA
}

enum TipoNegocio {
  GYM
  STORE
  MIXTO
}

enum TenantEstado {
  ACTIVO
  SUSPENDIDO
  ELIMINADO
}

enum TenantRole {
  OWNER
  ADMIN
  EMPLEADO
  ENTRENADOR
  RECEPCIONISTA
  CAJERO
}

enum UserTenantEstado {
  ACTIVO
  PENDIENTE
  INACTIVO
}

enum ModuleKey {
  GYM
  STORE
}

enum EstadoClientePlan {
  ACTIVO
  CAMBIADO
  FINALIZADO
  CANCELADO
}

enum UnidadDuracion {
  MESES
  DIAS
}

enum EstadoDevolucion {
  PENDIENTE
  PARCIAL
  COMPLETADO
  NO_APLICA
}

model CambioPlan {
  id                          Int              @id @default(autoincrement())
  tenantId                    Int
  clienteId                   Int
  clientePlanAnteriorId       Int
  clientePlanNuevoId          Int
  montoPagadoTransferido      Float
  montoDevuelto               Float            @default(0)
  devolucionPendiente         Float            @default(0)
  devolucionDevueltaAcumulada Float            @default(0)
  fecha                       DateTime         @default(now())
  estadoDevolucion            EstadoDevolucion @default(PENDIENTE)
  motivo                      String?

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  cliente             Cliente      @relation(fields: [clienteId], references: [id])
  clientePlanAnterior ClientePlan  @relation("PlanAnterior", fields: [clientePlanAnteriorId], references: [id])
  clientePlanNuevo    ClientePlan  @relation("PlanNuevo", fields: [clientePlanNuevoId], references: [id])
  devoluciones        DevolucionMovimiento[]

  @@index([tenantId])
}

model DevolucionMovimiento {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  cambioPlanId Int
  facturaId    Int
  monto        Float
  fecha        DateTime  @default(now())
  motivo       String?
  usuarioId    Int?

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  cambioPlan CambioPlan @relation(fields: [cambioPlanId], references: [id])
  factura    Factura    @relation(fields: [facturaId], references: [id])
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id])

  @@index([tenantId])
  @@index([cambioPlanId])
  @@index([facturaId])
  @@index([fecha])
}
