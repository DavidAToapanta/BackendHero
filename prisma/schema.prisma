// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int    @id @default(autoincrement())
  userName        String
  password        String
  nombres         String
  apellidos       String
  cedula          String @unique
  fechaNacimiento String

  administrador Administrador[]
  entrenador    Entrenador[]
  recepcionista Recepcionista[]
  cliente       Cliente[]
  gastos        Gasto[]
}

model Administrador {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Entrenador {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  horario   String
  sueldo    Float
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Recepcionista {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  horario   String
  sueldo    Float
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Cliente {
  id             Int    @id
  usuarioId      Int    @unique
  horario        String
  sexo           String
  observaciones  String
  objetivos      String
  tiempoEntrenar Int
  activo         Boolean @default(true)

  usuario        Usuario         @relation(fields: [usuarioId], references: [id])
  clienteMedidas ClienteMedida[]
  novedades      Novedad[]
  compras        Compra[]
  planes         ClientePlan[]
  rutinas        Rutina[]
  asistencias    Asistencia[]
  cambiosPlan    CambioPlan[]
}

model Medida {
  id             Int             @id @default(autoincrement())
  nombre         String
  clienteMedidas ClienteMedida[]
}

model ClienteMedida {
  id        Int @id @default(autoincrement())
  clienteId Int
  medidaId  Int
  medida    Int

  cliente    Cliente @relation(fields: [clienteId], references: [id])
  medidaTipo Medida  @relation(fields: [medidaId], references: [id])
}

model Novedad {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  novedad    String
  fecha      DateTime
  solventada Boolean

  cliente Cliente @relation(fields: [clienteId], references: [id])
}

model Producto {
  id     Int     @id @default(autoincrement())
  nombre String
  precio Float
  stock  Int
  estado Boolean

  compras Compra[]
}

model Compra {
  id         Int      @id @default(autoincrement())
  productoId Int
  clienteId  Int
  cantidad   Int
  total      Float
  fecha      DateTime

  producto Producto @relation(fields: [productoId], references: [id])
  cliente  Cliente  @relation(fields: [clienteId], references: [id])
}

model Plan {
  id              Int             @id @default(autoincrement())
  nombre          String
  precio          Float
  duracion        Int
  unidadDuracion  UnidadDuracion  @default(MESES)
  activo          Boolean         @default(true)
  clientePlan     ClientePlan[]
}

model ClientePlan {
  id          Int                @id @default(autoincrement())
  clienteId   Int
  planId      Int
  fechaInicio DateTime
  fechaFin    DateTime
  diaPago     Int
  activado    Boolean
  estado      EstadoClientePlan  @default(ACTIVO)

  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  plan            Plan         @relation(fields: [planId], references: [id])
  pago            Pago[]
  deudas          Deuda[]
  facturas        Factura[]
  cambiosComoAnterior CambioPlan[] @relation("PlanAnterior")
  cambiosComoNuevo    CambioPlan[] @relation("PlanNuevo")
}

model Pago {
  id            Int      @id @default(autoincrement())
  clientePlanId Int
  monto         Float
  fecha         DateTime

  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])

  @@index([clientePlanId])
  @@index([fecha])
}

model Deuda {
  id            Int     @id @default(autoincrement())
  clientePlanId Int
  monto         Float
  solventada    Boolean

  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])
}

model Rutina {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  rutina      Bytes
  fechaInicio DateTime
  fechaFin    DateTime
  observacion String

  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  entrenamiento Entrenamiento? @relation("RutinaEntrenamiento") // sin fields ni references
}

model Entrenamiento {
  id         Int     @id @default(autoincrement())
  rutinaId   Int     @unique
  finalizado Boolean

  rutina  Rutina   @relation("RutinaEntrenamiento", fields: [rutinaId], references: [id])
  semanas Semana[]
}

model Semana {
  id              Int             @id @default(autoincrement())
  numero          Int
  entrenamientoId Int
  entrenamiento   Entrenamiento   @relation(fields: [entrenamientoId], references: [id])
  musculosSemana  MusculoSemana[]
}

model MusculoSemana {
  id        Int @id @default(autoincrement())
  semanaId  Int
  musculoId Int
  orden     Int // Orden en que se entrena este músculo en la semana

  semana            Semana             @relation(fields: [semanaId], references: [id])
  musculo           Musculo            @relation(fields: [musculoId], references: [id])
  ejerciciosMusculo EjercicioMusculo[]
}

model Musculo {
  id             Int             @id @default(autoincrement())
  nombre         String          @unique
  musculosSemana MusculoSemana[]
}

model EjercicioMusculo {
  id              Int @id @default(autoincrement())
  musculoSemanaId Int
  ejercicioId     Int
  orden           Int // Orden en que se hace este ejercicio para el músculo

  musculoSemana MusculoSemana @relation(fields: [musculoSemanaId], references: [id])
  ejercicio     Ejercicio     @relation(fields: [ejercicioId], references: [id])
  seriesReps    SerieRep[]
  seriesTiempos SerieTiempo[]
}

model Ejercicio {
  id     Int    @id @default(autoincrement())
  nombre String @unique
  foto   Bytes? // Keeping foto from HEAD just in case

  ejerciciosMusculo EjercicioMusculo[]
}

model SerieRep {
  id                 Int    @id @default(autoincrement())
  ejercicioMusculoId Int
  orden              Int
  peso               Float
  repeticiones       Int
  unidadMedida       String

  ejercicioMusculo EjercicioMusculo @relation(fields: [ejercicioMusculoId], references: [id])
}

model SerieTiempo {
  id                 Int    @id @default(autoincrement())
  ejercicioMusculoId Int
  orden              Int
  peso               Float
  tiempo             Int
  unidadMedida       String

  ejercicioMusculo EjercicioMusculo @relation(fields: [ejercicioMusculoId], references: [id])
}

model Gasto {
  id          Int      @id @default(autoincrement())
  descripcion String
  monto       Float
  fecha       DateTime @default(now())
  usuarioId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}

model Asistencia {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  fecha       DateTime @default(now())
  horaEntrada DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@unique([clienteId, fecha(sort: Desc)]) // Solo 1 asistencia por día
  @@index([clienteId, fecha])
}

model Factura {
  id            Int    @id @default(autoincrement())
  numero        String @unique
  clientePlanId Int

  subtotal Float
  iva      Float
  total    Float

  totalPagado     Float @default(0)
  creditoAplicado Float @default(0)
  saldo           Float

  estado       EstadoFactura
  fechaEmision DateTime      @default(now())

  clientePlan ClientePlan @relation(fields: [clientePlanId], references: [id])
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  ANULADA
}

enum EstadoClientePlan {
  ACTIVO
  CAMBIADO
  FINALIZADO
  CANCELADO
}

enum UnidadDuracion {
  MESES
  DIAS
}

enum EstadoDevolucion {
  PENDIENTE
  COMPLETADO
  NO_APLICA
}

model CambioPlan {
  id                     Int              @id @default(autoincrement())
  clienteId              Int
  clientePlanAnteriorId  Int
  clientePlanNuevoId     Int
  montoPagadoTransferido Float
  montoDevuelto          Float            @default(0)
  fecha                  DateTime         @default(now())
  estadoDevolucion       EstadoDevolucion @default(PENDIENTE)
  motivo                 String?

  cliente             Cliente     @relation(fields: [clienteId], references: [id])
  clientePlanAnterior ClientePlan @relation("PlanAnterior", fields: [clientePlanAnteriorId], references: [id])
  clientePlanNuevo    ClientePlan @relation("PlanNuevo", fields: [clientePlanNuevoId], references: [id])
}
